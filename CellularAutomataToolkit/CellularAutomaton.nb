Cell[CellGroupData[{

Cell["Testing", "Subsection",
 CellChangeTimes->{{3.9069925090015345`*^9, 3.906992536779458*^9}, {
  3.9069925725698442`*^9, 3.9069925843465643`*^9}, {3.906992857065667*^9, 
  3.9069928599807987`*^9}},ExpressionUUID->"f0317fd1-fff8-4cc9-b493-\
385654c4f116"],

Cell["\<\
These test functions are called during the initialization phase and are only \
necessary for testing the cellular automaton on non-real-world data. This \
part can be ignored if you intent to use this for real geographical data.\
\>", "Text",
 CellChangeTimes->{{3.906992593628955*^9, 3.9069926109114733`*^9}, {
  3.9069926559165545`*^9, 3.9069927224436913`*^9}, {3.9069928423403025`*^9, 
  3.906992848712307*^9}},ExpressionUUID->"b49ee917-7470-4aa5-93d0-\
e0b557c0c63a"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"groundHeightTestFunction", "[", "vertexCoordinate_List", "]"}], ":=", 
  RowBox[{
   RowBox[{"Sin", "[", 
    RowBox[{
     RowBox[{"vertexCoordinate", "[", 
      RowBox[{"[", "1", "]"}], "]"}], "/", "3"}], "]"}], "+", 
   RowBox[{"Sin", "[", 
    RowBox[{
     RowBox[{"vertexCoordinate", "[", 
      RowBox[{"[", "2", "]"}], "]"}], "/", "3"}], "]"}], "+", "3"}]}], "\n", 
 RowBox[{
  RowBox[{"waterHeightTestFunction", "[", "vertexCoordinate_List", "]"}], ":=",
   "1"}]}], "Code",
 CellChangeTimes->{{3.90469104146084*^9, 3.904691065785881*^9}, {
   3.904691098917863*^9, 3.904691104651291*^9}, {3.904691260200881*^9, 
   3.904691261684738*^9}, {3.9046919377339907`*^9, 3.9046919799597244`*^9}, 
   3.904693715869828*^9, {3.9046938383637967`*^9, 3.904693838921013*^9}, {
   3.906909945320345*^9, 3.906909945499588*^9}, {3.9069103182137628`*^9, 
   3.906910323124928*^9}, 3.906912648475229*^9, {3.906914502615362*^9, 
   3.9069145305349503`*^9}, 3.906942160965627*^9, {3.9069427646500273`*^9, 
   3.906942798624194*^9}, {3.906947658663436*^9, 3.906947662185983*^9}, {
   3.906960137354266*^9, 3.906960138229197*^9}, {3.9069926262460136`*^9, 
   3.906992648940198*^9}, {3.906992972076683*^9, 3.9069929725360093`*^9}, {
   3.906993165962564*^9, 3.9069932679567165`*^9}, {3.906993360383004*^9, 
   3.90699338314693*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"d7311d7a-afaa-441e-9a5a-ebc406669624"],

Cell["\<\
Generate a hexagonal graph, initialize the vertex data based on the above \
functions, then run the simulation and visualize. \
\>", "Text",
 CellChangeTimes->{{3.9069928895527334`*^9, 
  3.906992924971362*^9}},ExpressionUUID->"ee029a51-5b98-4f3e-8397-\
2a50dc325720"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"graph", "=", 
   RowBox[{"HexagonalGraphGen", "[", 
    RowBox[{"20", ",", "20"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"InitVertexData", "[", 
   RowBox[{
   "graph", ",", "groundHeightTestFunction", ",", "waterHeightTestFunction"}],
    "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"generatedData", "=", 
   RowBox[{"GenerateWaterData", "[", 
    RowBox[{"graph", ",", "20", ",", " ", "0.9"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9069580361930404`*^9, 3.9069580696322823`*^9}, {
   3.9069589951560545`*^9, 3.9069589953524*^9}, {3.906960087589634*^9, 
   3.906960195189619*^9}, 3.906961144963133*^9, {3.906992148916828*^9, 
   3.9069921595569534`*^9}, {3.9069923427268157`*^9, 
   3.9069923712632313`*^9}, {3.906992446731976*^9, 3.906992447732402*^9}, {
   3.9069932847118473`*^9, 3.9069932888048015`*^9}, {3.9069933248289833`*^9, 
   3.906993353323024*^9}, {3.906993418445776*^9, 3.906993435917238*^9}},
 CellLabel->"In[9]:=",ExpressionUUID->"b49b75c5-7d05-4648-b90b-9a040f48ee77"],

Cell["Visualization", "Text",
 CellChangeTimes->{{3.9069934384393144`*^9, 
  3.9069934437234726`*^9}},ExpressionUUID->"0cc78d10-9aaf-4307-b64b-\
b894a84e53b2"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"ListAnimate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"VisualizeWaterData3D", "[", 
     RowBox[{"graph", ",", "#"}], "]"}], "&"}], "/@", "generatedData"}], 
  "]"}], "\[IndentingNewLine]", 
 RowBox[{"ListAnimate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"VisualizeWaterData", "[", 
     RowBox[{"graph", ",", "#", ",", "0.5", ",", "0.01"}], "]"}], "&"}], "/@",
    "generatedData"}], "]"}]}], "Input",
 CellChangeTimes->{{3.9069934470576*^9, 3.9069934593016024`*^9}, {
  3.9069934902687206`*^9, 3.9069935006433687`*^9}},

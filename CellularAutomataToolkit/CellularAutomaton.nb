Cell[CellGroupData[{

Cell["Real World Data", "Subsection",
 CellChangeTimes->{{3.9069928699785404`*^9, 
  3.90699287509971*^9}},ExpressionUUID->"147e71c9-6e92-4b27-b4fd-\
b23b602dc8e5"],

Cell["\<\
We initialize the cellular automata by specifying a geo position, a range in \
km (which is the width of the square we are getting data from), a node \
density in the form of nodes per square kilometer, and the initial height of \
water in meters.\
\>", "Text",
 CellChangeTimes->{{3.9069936187805557`*^9, 3.906993671544626*^9}, {
  3.906993777270562*^9, 3.90699378837053*^9}, {3.9069939032147474`*^9, 
  3.9069939156278415`*^9}},ExpressionUUID->"29e7135a-9573-42cc-baec-\
30d439864e8c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"graph", "=", 
   RowBox[{"InitializeCellularAutomata", "[", 
    RowBox[{
     RowBox[{"GeoPosition", "[", 
      TemplateBox[{"\"Cupertino\"", 
        RowBox[{"Entity", "[", 
          RowBox[{"\"City\"", ",", 
            RowBox[{"{", 
              
              RowBox[{"\"Cupertino\"", ",", "\"California\"", ",", 
                "\"UnitedStates\""}], "}"}]}], "]"}], 
        "\"Entity[\\\"City\\\", {\\\"Cupertino\\\", \\\"California\\\", \
\\\"UnitedStates\\\"}]\"", "\"city\""},
       "Entity"], "]"}], ",", "10", ",", "2", ",", "1000"}], " ", 
    RowBox[{"(*", 
     RowBox[{
      RowBox[{
      "1000", " ", "meters", " ", "is", " ", "used", " ", "for", " ", "ease", 
       " ", "of", " ", 
       RowBox[{"viewing", ".", " ", "Not"}], " ", "an", " ", "actual", " ", 
       "real"}], "-", 
      RowBox[{"life", " ", "rainfall", " ", "scenario"}]}], "*)"}], "]"}]}], 
  ";"}]], "Input",
 CellChangeTimes->{
  3.9069580024550424`*^9, {3.9069583104205923`*^9, 3.9069583402187138`*^9}, 
   3.9069583783056655`*^9, {3.9069585366381283`*^9, 3.906958540913973*^9}, {
   3.906959306322316*^9, 3.906959309093*^9}, {3.906959344249191*^9, 
   3.906959345533375*^9}, {3.9069924510701694`*^9, 3.9069924558604083`*^9}, 
   3.9069936142011237`*^9, 3.90699401782264*^9, {3.9069940690459747`*^9, 
   3.9069940848926706`*^9}, {3.90699444399325*^9, 3.906994444313323*^9}, 
   3.906996443854972*^9, {3.9069965946679583`*^9, 3.9069965968234587`*^9}, {
   3.906996634167061*^9, 
   3.906996672123122*^9}},ExpressionUUID->"31823d43-38e4-475c-a09e-\
8669b4b4e126"],

Cell["\<\
We then generate the water flow simulation data with the specified graph, a \
number of iterations, and the flow rate, which is a number from 0 to 1\
\>", "Text",
 CellChangeTimes->{{3.906994022359961*^9, 3.9069940540547333`*^9}, {
  3.9069940905159807`*^9, 
  3.9069941125739045`*^9}},ExpressionUUID->"bcbaa70b-d527-476b-b591-\
7076d584badf"],

Cell[BoxData[
 RowBox[{
  RowBox[{"generatedData", "=", 
   RowBox[{"GenerateWaterData", "[", 
    RowBox[{"graph", ",", "20", ",", " ", "0.9"}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.906994041248127*^9, 3.9069940428948655`*^9}, {
  3.906996555911518*^9, 3.9069965634503136`*^9}},
 CellLabel->"In[28]:=",ExpressionUUID->"7ab9de4f-fdb1-464e-846f-28155553e9ce"],

Cell["\<\
We can then visualize the generated water flow data using different \
visualization functions.\
\>", "Text",
 CellChangeTimes->{{3.90699411517982*^9, 
  3.9069941439126263`*^9}},ExpressionUUID->"44344179-257c-4544-bb21-\
e76e78a64959"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ListAnimate", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"VisualizeWaterData3D", "[", 
     RowBox[{"graph", ",", "#"}], "]"}], "&"}], "/@", "generatedData"}], 
  "]"}]], "Input",
 CellLabel->"In[29]:=",ExpressionUUID->"4501b979-fa57-42a0-8c37-12b16dd89f8a"],

